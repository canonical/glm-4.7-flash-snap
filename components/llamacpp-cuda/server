#!/bin/bash -eu
port="$(modelctl get http.port)"
host="$(modelctl get http.host)"
mmproj_args=()
if [ -n "${MMPROJ_FILE:-}" ]; then
  mmproj_args=(--mmproj "$MMPROJ_FILE")
fi
verbose="$(modelctl get verbose)"
EXTRA_ARGS=()
if [ "${verbose}" = "true" ]; then EXTRA_ARGS+=(--verbose); fi
# Reserve VRAM headroom for CUDA: 1024 MiB + any mmproj size
free_vram=1024
if [ -n "${MMPROJ_FILE:-}" ]; then
  mmproj_size=$(stat -c%s "$MMPROJ_FILE" 2>/dev/null || echo 0)
  free_vram=$((free_vram + mmproj_size / 1048576))
fi
EXTRA_ARGS+=("--cont-batching" "--parallel-reserve" "$free_vram")
set -x
exec llama-server \
  --model "$MODEL_FILE" \
  --alias "$MODEL_NAME" \
  "${mmproj_args[@]}" \
  --port "$port" \
  --host "$host" \
  --no-warmup \
  "${EXTRA_ARGS[@]}" \
  "$@"
